# Base de datos / Supabase
DATABASE_URL=                       # rol de administración (dueño de tablas) — solo Alembic/scripts
APP_DATABASE_URL=                   # rol restringido `app_user` (sin BYPASSRLS) — lo usa el backend en runtime
APP_DB_PASSWORD=                    # contraseña de `app_user`; la lee la migración 0001 al crear el rol
SUPABASE_URL=                       # OBLIGATORIO: p.ej. https://<proyecto>.supabase.co
SUPABASE_ANON_KEY=                  # obligatorio en producción
SUPABASE_SERVICE_ROLE_KEY=          # obligatorio en producción

# IA
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Backend
SECRET_KEY=                         # obligatorio en producción
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
